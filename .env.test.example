# E2E Test Environment Variables
# Copy to .env.test and fill in values for your test environment

# Base URL for Playwright tests (defaults to http://localhost:3000)
BASE_URL=http://localhost:3000

# Test user credentials (must exist in the users table)
E2E_END_USER_USERNAME=user
E2E_END_USER_PASSWORD=password

E2E_IT_STAFF_USERNAME=it_admin
E2E_IT_STAFF_PASSWORD=password

E2E_ADMIN_USERNAME=it_admin
E2E_ADMIN_PASSWORD=password
