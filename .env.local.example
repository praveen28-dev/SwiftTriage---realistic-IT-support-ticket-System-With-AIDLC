# ============================================================
# SwiftTriage - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Database Configuration (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
DATABASE_URL=

# Groq AI API Key
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# NextAuth Configuration
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Application Configuration (Optional)
POLLING_INTERVAL=5000

# Google Analytics 4 (Optional)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Demo Credentials Visibility
# Set to 'true' for development/demo only — always 'false' in production
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
