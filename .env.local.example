# ============================================================
# SwiftTriage - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Database Configuration (Neon PostgreSQL)
# Get your connection string from https://console.neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
# REQUIRED for authentication system to store user credentials and sessions
DATABASE_URL=

# Groq AI API Key
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# NextAuth Configuration
# REQUIRED: Secret key for signing JWT tokens (minimum 32 characters, 256 bits)
# Generate secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CRITICAL: Use a cryptographically secure random value in production
# NEVER commit this value to version control
NEXTAUTH_SECRET=your_nextauth_secret_here

# REQUIRED: Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# Password Hashing Configuration
# OPTIONAL: bcrypt salt rounds for password hashing (default: 12, min: 12, max: 15)
# Higher values = more secure but slower authentication
# Recommended: 12 for most applications, 13-15 for high-security requirements
# Each increment doubles the computation time
BCRYPT_SALT_ROUNDS=12

# Application Configuration (Optional)
POLLING_INTERVAL=5000

# Google Analytics 4 (Optional)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Demo Credentials Visibility
# Set to 'true' for development/demo only — always 'false' in production
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true
